/* Global Styles */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 30rpx;
  color: #333333;
  background-color: #f5f6f7;
  box-sizing: border-box;
}

/* Reset native button styles */
button {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
  border-radius: 0;
  line-height: inherit;
  font-size: inherit;
  color: inherit;
}

button::after {
  border: none;
}

button[disabled] {
  color: inherit;
}

/* Common Layout */
.container {
  padding: 24rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* Card Styles */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* Text Styles */
.text-primary {
  color: #1976d2;
}

.text-success {
  color: #19be6b;
}

.text-warning {
  color: #ff9900;
}

.text-danger {
  color: #ed4014;
}

.text-grey {
  color: #999999;
}

.text-bold {
  font-weight: 600;
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-center {
  text-align: center;
}

/* Button Styles */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  padding: 0 32rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background-color: #1976d2;
  color: #ffffff;
}

.btn-primary:active {
  background-color: #2480e3;
}

.btn-success {
  background-color: #19be6b;
  color: #ffffff;
}

.btn-warning {
  background-color: #ff9900;
  color: #ffffff;
}

.btn-danger {
  background-color: #ed4014;
  color: #ffffff;
}

.btn-default {
  background-color: #f0f0f0;
  color: #666666;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid #1976d2;
  color: #1976d2;
}

.btn-block {
  width: 100%;
}

.btn-sm {
  height: 64rpx;
  font-size: 26rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
}

.btn-lg {
  height: 96rpx;
  font-size: 32rpx;
}

/* Form Styles */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  height: 80rpx;
  background-color: #f5f6f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  width: 100%;
  box-sizing: border-box;
}

.form-textarea {
  background-color: #f5f6f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
}

/* Tag Styles */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.tag-blue {
  background-color: #e8f4ff;
  color: #1976d2;
}

.tag-green {
  background-color: #e8f8ef;
  color: #19be6b;
}

.tag-orange {
  background-color: #fff3e0;
  color: #ff9900;
}

.tag-red {
  background-color: #fde8e8;
  color: #ed4014;
}

.tag-grey {
  background-color: #f0f0f0;
  color: #999999;
}

/* Divider */
.divider {
  height: 1rpx;
  background-color: #eeeeee;
  margin: 20rpx 0;
}

/* Loading */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999999;
}

/* Empty State */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* Safe Area */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
