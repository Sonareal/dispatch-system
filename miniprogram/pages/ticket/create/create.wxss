.page-create {
  min-height: 100vh;
  background-color: #f5f6f7;
  padding-bottom: 160rpx;
}

.form-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  padding: 28rpx 0 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ocr-scan-btn {
  padding: 8rpx 20rpx;
  background: #e3f2fd;
  border-radius: 24rpx;
}

.ocr-scan-text {
  font-size: 24rpx;
  color: #1976d2;
  font-weight: 500;
}

.location-btn {
  display: inline-flex;
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background: #e8f5e9;
  border-radius: 20rpx;
}

.location-btn-text {
  font-size: 22rpx;
  color: #2e7d32;
  font-weight: 500;
}

.ocr-result {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
}

.form-label {
  display: flex;
  align-items: center;
}

.form-group {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f6f7;
}

.form-group:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.required {
  color: #ed4014;
  margin-right: 6rpx;
}

.form-input {
  height: 72rpx;
  background-color: #f5f6f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
}

.form-textarea {
  background-color: #f5f6f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  width: 100%;
  min-height: 140rpx;
  box-sizing: border-box;
}

.picker-value {
  height: 72rpx;
  background-color: #f5f6f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value.placeholder {
  color: #cccccc;
}

.picker-arrow {
  font-size: 20rpx;
  color: #cccccc;
}

/* Action Buttons */
.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}
