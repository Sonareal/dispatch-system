<view class="page-detail">
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-wrap" style="padding-top: 200rpx;">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{ticket}}">
    <!-- Status Header -->
    <view class="status-header" style="background-color: {{statusInfo.color}};">
      <view class="status-content">
        <text class="status-text">{{statusInfo.text}}</text>
        <text class="ticket-no" bindtap="copyTicketNo">{{ticket.ticket_no || ('工单#' + ticket.id)}} (点击复制)</text>
      </view>
    </view>

    <!-- Customer Info -->
    <view class="detail-card">
      <view class="card-title">客户信息</view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">客户姓名</text>
          <text class="info-value">{{ticket.customer_name || '-'}}</text>
        </view>
        <view class="info-item" bindtap="makePhoneCall">
          <text class="info-label">联系电话</text>
          <text class="info-value text-primary">{{ticket.customer_phone || '-'}} [拨打]</text>
        </view>
        <view class="info-item">
          <text class="info-label">身份证号</text>
          <text class="info-value">{{ticket.id_card_masked || '-'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">所属城市</text>
          <text class="info-value">{{ticket.city_name || '-'}}</text>
        </view>
        <view class="info-item full-width">
          <text class="info-label">所属区域</text>
          <text class="info-value">{{ticket.region_path || ticket.region_name || '-'}}</text>
        </view>
        <view class="info-item full-width">
          <text class="info-label">详细地址</text>
          <text class="info-value">{{ticket.address || '-'}}</text>
        </view>
      </view>
    </view>

    <!-- Loan Info -->
    <view class="detail-card">
      <view class="card-title">贷款信息</view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">申请金额</text>
          <text class="info-value text-danger text-bold">￥{{ticket.apply_amount_fmt}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">还款方式</text>
          <text class="info-value">{{ticket.repayment_method || '-'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">查勘费</text>
          <text class="info-value">￥{{ticket.inspection_fee_fmt}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">业务员</text>
          <text class="info-value">{{ticket.salesman || '-'}}</text>
        </view>
      </view>
    </view>

    <!-- Remark -->
    <view class="detail-card" wx:if="{{ticket.remark}}">
      <view class="card-title">备注</view>
      <view class="remark-content">
        <text>{{ticket.remark}}</text>
      </view>
    </view>

    <!-- Time Info -->
    <view class="detail-card">
      <view class="card-title">时间信息</view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">创建时间</text>
          <text class="info-value">{{ticket.created_at_fmt || '-'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">更新时间</text>
          <text class="info-value">{{ticket.updated_at_fmt || '-'}}</text>
        </view>
      </view>
    </view>

    <!-- Flow Records -->
    <view class="detail-card" wx:if="{{flowRecords.length > 0}}">
      <view class="card-title">流转记录</view>
      <view class="timeline">
        <view class="timeline-item" wx:for="{{flowRecords}}" wx:key="id">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <view class="timeline-header">
              <text class="timeline-action">{{item.action || item.description || '操作'}}</text>
              <text class="timeline-time">{{item.created_at_fmt}}</text>
            </view>
            <text class="timeline-operator" wx:if="{{item.operator}}">操作人: {{item.operator}}</text>
            <text class="timeline-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Audit Records -->
    <view class="detail-card" wx:if="{{auditRecords.length > 0}}">
      <view class="card-title">审核记录</view>
      <view class="timeline">
        <view class="timeline-item" wx:for="{{auditRecords}}" wx:key="id">
          <view class="timeline-dot {{item.action === 'approve' ? 'dot-green' : item.action === 'reject' ? 'dot-red' : ''}}"></view>
          <view class="timeline-content">
            <view class="timeline-header">
              <text class="timeline-action">
                {{item.action === 'approve' ? '审核通过' : item.action === 'reject' ? '审核驳回' : (item.action || '审核')}}
              </text>
              <text class="timeline-time">{{item.created_at_fmt}}</text>
            </view>
            <text class="timeline-operator" wx:if="{{item.auditor || item.operator}}">审核人: {{item.auditor || item.operator}}</text>
            <text class="timeline-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Voice Call Button - shown when ticket has assignee and is in active status -->
    <view class="detail-card call-card" wx:if="{{ticket.assignee_id && (ticket.status === 'assigned' || ticket.status === 'processing' || ticket.status === 'transferred')}}">
      <view class="call-row">
        <view class="call-info">
          <text class="call-title">语音通话</text>
          <text class="call-desc">与{{ticket.assignee_id === currentUserId ? ticket.submitter_name : ticket.assignee_name}}实时语音沟通</text>
        </view>
        <view class="call-btn" bindtap="initiateCall">
          <text class="call-btn-icon">C</text>
          <text class="call-btn-text">拨打</text>
        </view>
      </view>
    </view>

    <!-- Messages -->
    <view class="detail-card">
      <view class="card-title">沟通记录</view>
      <view wx:if="{{messages.length > 0}}">
        <view class="msg-item {{item.is_read ? '' : 'msg-unread'}}" wx:for="{{messages}}" wx:key="id">
          <view class="msg-header">
            <view style="display:flex;align-items:center;">
              <text class="msg-sender">{{item.sender_name}}</text>
              <text wx:if="{{!item.is_read}}" class="msg-unread-dot"></text>
            </view>
            <view style="display:flex;align-items:center;">
              <text class="msg-time">{{item.created_at}}</text>
              <text wx:if="{{item.is_mine}}" class="msg-delete-btn" catchtap="onDeleteMessage" data-id="{{item.id}}">删除</text>
            </view>
          </view>
          <view class="msg-body">
            <text wx:if="{{item.msg_type === 'text'}}">{{item.content}}</text>
            <view wx:elif="{{item.msg_type === 'voice'}}" class="voice-msg" bindtap="onPlayVoice" data-id="{{item.id}}" data-url="{{item.file_url}}">
              <view class="voice-play-btn">
                <view wx:if="{{playingMsgId === item.id}}" class="pause-icon">
                  <view class="pause-bar"></view>
                  <view class="pause-bar"></view>
                </view>
                <view wx:else class="play-triangle"></view>
              </view>
              <view class="voice-progress-wrap">
                <view class="voice-progress-bar">
                  <view class="voice-progress-fill" style="width: {{playingMsgId === item.id ? playingProgress + '%' : '0%'}}"></view>
                </view>
                <view class="voice-time-row">
                  <text class="voice-time">{{playingMsgId === item.id ? playingTimeText : '0:00'}}</text>
                  <text class="voice-time">{{playingMsgId === item.id && playingTotalText ? playingTotalText : (item.durationText || '')}}</text>
                </view>
              </view>
            </view>
            <text wx:elif="{{item.msg_type === 'image'}}">[图片消息]</text>
            <text wx:elif="{{item.msg_type === 'system'}}" style="color:#999;">{{item.content}}</text>
            <text wx:else>{{item.content || item.file_url}}</text>
          </view>
        </view>
      </view>
      <view wx:else style="text-align:center;padding:20rpx;color:#999;">暂无沟通记录</view>

      <!-- Recording Overlay -->
      <view wx:if="{{isRecording}}" class="recording-overlay">
        <view class="recording-indicator">
          <view class="recording-dot"></view>
          <text class="recording-text">录音中 {{recordingDuration}}s</text>
          <text class="recording-hint">松开手指发送，上滑取消</text>
        </view>
      </view>

      <!-- Input Mode Toggle + Input Bar -->
      <view class="msg-input-bar">
        <!-- Toggle button: switch between text and voice mode -->
        <view class="input-mode-toggle" bindtap="toggleInputMode">
          <text class="toggle-icon">{{inputMode === 'voice' ? '键盘' : '语音'}}</text>
        </view>

        <!-- Text input mode -->
        <block wx:if="{{inputMode === 'text'}}">
          <input class="msg-input" placeholder="输入消息..." value="{{msgContent}}" bindinput="onMsgInput" confirm-type="send" bindconfirm="sendMessage" />
          <view class="send-btn" bindtap="sendMessage">发送</view>
        </block>

        <!-- Voice input mode -->
        <block wx:else>
          <view class="voice-hold-btn {{isRecording ? 'voice-hold-active' : ''}}"
            bindtouchstart="onVoiceBtnTouchStart"
            bindtouchend="onVoiceBtnTouchEnd"
            bindtouchcancel="onVoiceBtnTouchEnd">
            <text>{{isRecording ? '松开发送' : '按住说话'}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- Action Buttons -->
    <view class="action-bar safe-bottom" wx:if="{{!loading}}">
      <!-- Draft -->
      <block wx:if="{{ticket.status === 'draft'}}">
        <view class="btn btn-primary" style="flex:1;" bindtap="handleSubmitTicket">提交审核</view>
      </block>

      <!-- Pending Review -->
      <block wx:elif="{{ticket.status === 'pending_review'}}">
        <view class="btn btn-default" style="flex:1; margin-right:16rpx;" bindtap="handleWithdraw">撤回</view>
        <view class="btn btn-danger" style="flex:1; margin-right:16rpx;" bindtap="handleAuditReject">驳回</view>
        <view class="btn btn-success" style="flex:1; margin-right:16rpx;" bindtap="handleAuditApprove">通过</view>
        <view class="btn btn-primary" style="flex:1;" bindtap="handleAssign">指派</view>
      </block>

      <!-- Rejected: re-edit and resubmit -->
      <block wx:elif="{{ticket.status === 'rejected'}}">
        <view class="btn btn-primary" style="flex:1;" bindtap="handleSubmitTicket">重新提交审核</view>
      </block>

      <!-- Approved: assign -->
      <block wx:elif="{{ticket.status === 'approved' || ticket.status === 'pending_assign'}}">
        <view class="btn btn-primary" style="flex:1;" bindtap="handleAssign">指派</view>
      </block>

      <!-- Assigned: start / transfer / re-assign -->
      <block wx:elif="{{ticket.status === 'assigned'}}">
        <view class="btn btn-primary" style="flex:1; margin-right:16rpx;" bindtap="handleUpdateStatus" data-status="processing">开始处理</view>
        <view class="btn btn-outline" style="flex:1; margin-right:16rpx;" bindtap="handleTransfer">转派</view>
        <view class="btn btn-warning" style="flex:1;" bindtap="handleAssign">重新指派</view>
      </block>

      <!-- Processing -->
      <block wx:elif="{{ticket.status === 'processing'}}">
        <view class="btn btn-outline" style="flex:1; margin-right:16rpx;" bindtap="handleTransfer">转派</view>
        <view class="btn btn-success" style="flex:1;" bindtap="handleUpdateStatus" data-status="completed">完成</view>
      </block>

      <!-- Transferred: re-transfer / process / complete -->
      <block wx:elif="{{ticket.status === 'transferred'}}">
        <view class="btn btn-primary" style="flex:1; margin-right:16rpx;" bindtap="handleUpdateStatus" data-status="processing">开始处理</view>
        <view class="btn btn-success" style="flex:1; margin-right:16rpx;" bindtap="handleUpdateStatus" data-status="completed">完成</view>
        <view class="btn btn-outline" style="flex:1;" bindtap="handleTransfer">再次转派</view>
      </block>

      <!-- Completed: admin can revert -->
      <block wx:elif="{{ticket.status === 'completed'}}">
        <view class="btn btn-warning" style="flex:1;" bindtap="handleRevertToReview">打回重审</view>
      </block>
    </view>
  </block>

  <!-- Remark Modal -->
  <view class="modal-mask" wx:if="{{showRemarkModal}}" bindtap="closeRemarkModal"></view>
  <view class="modal-dialog" wx:if="{{showRemarkModal}}">
    <view class="modal-title">
      {{actionType === 'approve' ? '审核通过 - 选择指派人员' : actionType === 'reject' ? '审核驳回' : actionType === 'assign' ? '指派工单' : actionType === 'transfer' ? '转派工单' : '更新状态'}}
    </view>

    <!-- User selection list for assign/approve/transfer -->
    <view wx:if="{{actionType === 'assign' || actionType === 'transfer' || actionType === 'approve'}}" style="padding: 0 30rpx; max-height: 400rpx; overflow-y: auto;">
      <view class="form-label" style="margin-bottom:16rpx;">选择处理人员（按工作负载排序）</view>
      <view wx:if="{{assignableUsers.length === 0}}" style="text-align:center;padding:20rpx;color:#999;">暂无可指派人员</view>
      <view
        wx:for="{{assignableUsers}}" wx:key="id"
        class="user-select-item {{selectedUserId === item.id ? 'user-selected' : ''}}"
        bindtap="selectAssignUser" data-id="{{item.id}}"
      >
        <view class="user-select-main">
          <view class="user-select-name">
            <text>{{item.alias}}</text>
            <text wx:if="{{item.recommended}}" class="tag tag-green" style="margin-left:8rpx;font-size:20rpx;">推荐</text>
            <text wx:if="{{item.is_region_match}}" class="tag tag-blue" style="margin-left:8rpx;font-size:20rpx;">区域匹配</text>
          </view>
          <text class="user-select-phone">{{item.phone || '-'}}</text>
        </view>
        <view class="user-select-meta">
          <text>角色: {{item.role_text || '-'}}</text>
          <text style="margin-left:16rpx;">区域: {{item.region_text || '-'}}</text>
          <text style="margin-left:16rpx;" class="{{item.workload > 3 ? 'text-danger' : item.workload > 0 ? 'text-warning' : 'text-success'}}">
            负载: {{item.workload}}单
          </text>
        </view>
      </view>
    </view>

    <view class="form-group" style="padding: 0 30rpx; margin-top: 16rpx;">
      <view class="form-label">备注{{actionType === 'reject' ? '（驳回原因，必填）' : ''}}</view>
      <textarea
        class="form-textarea"
        placeholder="请输入备注信息"
        value="{{actionRemark}}"
        bindinput="onRemarkInput"
        maxlength="200"
        auto-height
      />
    </view>

    <view class="modal-actions">
      <view class="btn btn-default" style="flex:1; margin-right:20rpx;" bindtap="closeRemarkModal">取消</view>
      <view class="btn btn-primary" style="flex:1;" bindtap="confirmAction">确认</view>
    </view>
  </view>
</view>
