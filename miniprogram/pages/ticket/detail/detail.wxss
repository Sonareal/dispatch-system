.page-detail {
  min-height: 100vh;
  background-color: #f5f6f7;
  padding-bottom: 180rpx;
}

/* Status Header */
.status-header {
  padding: 40rpx 30rpx;
  color: #ffffff;
}

.status-content {
  display: flex;
  flex-direction: column;
}

.status-text {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-header .ticket-no {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* Detail Card */
.detail-card {
  background-color: #ffffff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* Info Grid */
.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  padding-right: 16rpx;
}

.info-item.full-width {
  width: 100%;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 6rpx;
  display: block;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  display: block;
  word-break: break-all;
}

/* Remark */
.remark-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* Timeline */
.timeline {
  position: relative;
  padding-left: 30rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 2rpx;
  background-color: #e8e8e8;
}

.timeline-item {
  position: relative;
  padding-bottom: 28rpx;
  padding-left: 20rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -24rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #1976d2;
  border: 4rpx solid #e8f4ff;
}

.timeline-dot.dot-green {
  background-color: #19be6b;
  border-color: #e8f8ef;
}

.timeline-dot.dot-red {
  background-color: #ed4014;
  border-color: #fde8e8;
}

.timeline-content {
  display: flex;
  flex-direction: column;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.timeline-action {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.timeline-time {
  font-size: 22rpx;
  color: #cccccc;
}

.timeline-operator {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.timeline-remark {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

/* Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

/* Voice Call */
.call-card { background: linear-gradient(135deg, #e3f2fd, #f3e5f5) !important; }
.call-row { display: flex; align-items: center; justify-content: space-between; }
.call-info { display: flex; flex-direction: column; }
.call-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.call-desc { font-size: 24rpx; color: #666; }
.call-btn { display: flex; align-items: center; background-color: #2e7d32; color: #fff; padding: 16rpx 32rpx; border-radius: 40rpx; }
.call-btn:active { opacity: 0.8; }
.call-btn-icon { font-size: 28rpx; font-weight: 700; margin-right: 8rpx; }
.call-btn-text { font-size: 28rpx; font-weight: 600; }

/* Messages */
.msg-item {
  padding: 16rpx;
  margin-bottom: 12rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.msg-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.msg-sender {
  font-size: 24rpx;
  font-weight: 500;
  color: #1976d2;
}

.msg-time {
  font-size: 22rpx;
  color: #cccccc;
}

.msg-body {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.msg-input-bar {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.input-mode-toggle {
  width: 80rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.toggle-icon {
  font-size: 22rpx;
  color: #1976d2;
  font-weight: 600;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f6f7;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background-color: #1976d2;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.send-btn:active {
  opacity: 0.8;
}

.voice-hold-btn {
  flex: 1;
  height: 72rpx;
  background-color: #f5f6f7;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.voice-hold-btn:active,
.voice-hold-active {
  background-color: #e0e0e0;
  color: #d32f2f;
}

/* User Selection */
.user-select-item {
  padding: 20rpx;
  margin-bottom: 12rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.user-select-item.user-selected {
  background-color: #e6f7ff;
  border-color: #1976d2;
}

.user-select-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-select-name {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.user-select-phone {
  font-size: 24rpx;
  color: #999;
}

.user-select-meta {
  font-size: 22rpx;
  color: #666;
}

.text-success { color: #19be6b; }
.text-warning { color: #ff9900; }
.text-danger { color: #ed4014; }

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal-dialog {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 201;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-actions {
  display: flex;
  padding: 20rpx 30rpx 0;
}

/* ===== Recording Overlay ===== */
.recording-overlay {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.recording-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background-color: rgba(0, 0, 0, 0.7);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
}

.recording-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: #ed4014;
  margin-bottom: 12rpx;
  animation: recording-pulse 1s ease-in-out infinite;
}

@keyframes recording-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.recording-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.recording-hint {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* ===== Voice Message Bubble ===== */
.voice-msg {
  display: flex;
  align-items: center;
  background-color: #e6f7ff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  min-width: 200rpx;
}

.voice-play-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #1976d2;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.play-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 10rpx 0 10rpx 16rpx;
  border-color: transparent transparent transparent #ffffff;
  margin-left: 4rpx;
}

.pause-icon {
  display: flex;
  gap: 6rpx;
}

.pause-bar {
  width: 6rpx;
  height: 20rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

.voice-progress-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 12rpx;
  min-width: 200rpx;
}

.voice-progress-bar {
  height: 6rpx;
  background-color: #d0e4f7;
  border-radius: 3rpx;
  overflow: hidden;
}

.voice-progress-fill {
  height: 100%;
  background-color: #1976d2;
  border-radius: 3rpx;
  transition: width 0.3s linear;
}

.voice-time-row {
  display: flex;
  justify-content: space-between;
  margin-top: 6rpx;
}

.voice-time {
  font-size: 20rpx;
  color: #999;
}
