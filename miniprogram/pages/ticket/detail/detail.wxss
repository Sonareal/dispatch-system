.page-detail {
  min-height: 100vh;
  background-color: #f5f6f7;
  padding-bottom: 140rpx;
}

/* Status Header */
.status-header {
  padding: 40rpx 30rpx;
  color: #ffffff;
}

.status-content {
  display: flex;
  flex-direction: column;
}

.status-text {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-header .ticket-no {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* Detail Card */
.detail-card {
  background-color: #ffffff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* Info Grid */
.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  padding-right: 16rpx;
}

.info-item.full-width {
  width: 100%;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 6rpx;
  display: block;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  display: block;
  word-break: break-all;
}

/* Remark */
.remark-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* Timeline */
.timeline {
  position: relative;
  padding-left: 30rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 2rpx;
  background-color: #e8e8e8;
}

.timeline-item {
  position: relative;
  padding-bottom: 28rpx;
  padding-left: 20rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -24rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #2d8cf0;
  border: 4rpx solid #e8f4ff;
}

.timeline-dot.dot-green {
  background-color: #19be6b;
  border-color: #e8f8ef;
}

.timeline-dot.dot-red {
  background-color: #ed4014;
  border-color: #fde8e8;
}

.timeline-content {
  display: flex;
  flex-direction: column;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.timeline-action {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.timeline-time {
  font-size: 22rpx;
  color: #cccccc;
}

.timeline-operator {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.timeline-remark {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

/* Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

/* Messages */
.msg-item {
  padding: 16rpx;
  margin-bottom: 12rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.msg-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.msg-sender {
  font-size: 24rpx;
  font-weight: 500;
  color: #2d8cf0;
}

.msg-time {
  font-size: 22rpx;
  color: #cccccc;
}

.msg-body {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.msg-input-bar {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f6f7;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal-dialog {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 201;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-actions {
  display: flex;
  padding: 20rpx 30rpx 0;
}
