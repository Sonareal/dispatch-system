.page-index {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #2d8cf0 0%, #1a6dd1 100%);
  border-radius: 20rpx;
  padding: 36rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-greeting {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.banner-total {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
}

.total-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
}

.total-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* Stats Grid */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  flex: 1;
  min-width: calc(33% - 16rpx);
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-orange { color: #ff9900; }
.stat-blue { color: #2d8cf0; }
.stat-purple { color: #7c4dff; }
.stat-green { color: #19be6b; }
.stat-red { color: #ed4014; }

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

/* Notification Bar */
.notification-bar {
  display: flex;
  align-items: center;
  background-color: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.notification-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.notification-text {
  flex: 1;
  font-size: 26rpx;
  color: #d46b08;
}

.notification-arrow {
  font-size: 28rpx;
  color: #d46b08;
}

/* Section */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #2d8cf0;
}

/* Action Grid */
.action-grid {
  display: flex;
  justify-content: space-between;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.action-icon-blue { background-color: #2d8cf0; }
.action-icon-orange { background-color: #ff9900; }
.action-icon-green { background-color: #19be6b; }
.action-icon-purple { background-color: #7c4dff; }

.action-text {
  font-size: 24rpx;
  color: #666666;
}

/* Ticket Item */
.ticket-item {
  padding: 24rpx;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.ticket-no {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.ticket-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.ticket-customer {
  font-size: 26rpx;
  color: #666666;
}

.ticket-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #ed4014;
}

.ticket-footer {
  display: flex;
  justify-content: flex-end;
}

.ticket-time {
  font-size: 22rpx;
  color: #999999;
}
