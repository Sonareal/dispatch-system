<view class="call-page">
  <!-- Background -->
  <view class="bg-gradient"></view>

  <!-- Avatar area -->
  <view class="avatar-section">
    <view class="avatar-wrapper">
      <!-- Pulse rings for calling/incoming -->
      <view class="pulse-ring pulse-ring-1" wx:if="{{state === 'calling' || state === 'incoming'}}"></view>
      <view class="pulse-ring pulse-ring-2" wx:if="{{state === 'calling' || state === 'incoming'}}"></view>
      <view class="avatar">
        <text class="avatar-char">{{avatarChar}}</text>
      </view>
    </view>

    <!-- Name -->
    <text class="display-name">{{displayName}}</text>

    <!-- Status text -->
    <text class="status-text">{{statusText}}</text>

    <!-- Timer (connected state) -->
    <text class="timer-text" wx:if="{{state === 'connected'}}">{{durationText}}</text>

    <!-- Duration on ended -->
    <text class="end-duration" wx:if="{{state === 'ended' && endReason}}">{{endReason}}</text>
  </view>

  <!-- Sound wave animation (connected state) -->
  <view class="sound-waves" wx:if="{{state === 'connected'}}">
    <view class="wave wave-1"></view>
    <view class="wave wave-2"></view>
    <view class="wave wave-3"></view>
    <view class="wave wave-4"></view>
    <view class="wave wave-5"></view>
  </view>

  <!-- Action buttons -->
  <view class="actions">
    <!-- Calling state: hangup only -->
    <view class="btn-row" wx:if="{{state === 'calling'}}">
      <view class="action-btn btn-hangup" bindtap="hangupCall">
        <text class="btn-icon-text">X</text>
        <text class="btn-label">挂断</text>
      </view>
    </view>

    <!-- Incoming state: reject + accept -->
    <view class="btn-row btn-row-double" wx:if="{{state === 'incoming'}}">
      <view class="action-btn btn-reject" bindtap="rejectCall">
        <text class="btn-icon-text">X</text>
        <text class="btn-label">拒接</text>
      </view>
      <view class="action-btn btn-accept" bindtap="acceptCall">
        <text class="btn-icon-text">C</text>
        <text class="btn-label">接听</text>
      </view>
    </view>

    <!-- Connected state: hangup only -->
    <view class="btn-row" wx:if="{{state === 'connected'}}">
      <view class="action-btn btn-hangup" bindtap="hangupCall">
        <text class="btn-icon-text">X</text>
        <text class="btn-label">挂断</text>
      </view>
    </view>
  </view>
</view>
