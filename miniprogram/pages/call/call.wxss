.call-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  z-index: 0;
}

/* Avatar */
.avatar-section {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.avatar-char {
  font-size: 72rpx;
  color: #ffffff;
  font-weight: bold;
}

/* Pulse rings */
.pulse-ring {
  position: absolute;
  top: 50%; left: 50%;
  width: 160rpx; height: 160rpx;
  margin-top: -80rpx; margin-left: -80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(102, 126, 234, 0.6);
  z-index: 1;
}

.pulse-ring-1 { animation: pulse 2s ease-out infinite; }
.pulse-ring-2 { animation: pulse 2s ease-out infinite 1s; }

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(2.2); opacity: 0; }
}

.display-name {
  margin-top: 48rpx;
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 600;
}

.status-text {
  margin-top: 16rpx;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
}

.timer-text {
  margin-top: 40rpx;
  font-size: 72rpx;
  color: #ffffff;
  font-family: 'Menlo', 'Courier New', monospace;
  font-weight: 300;
  letter-spacing: 4rpx;
}

.end-duration {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* Sound waves */
.sound-waves {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 60rpx;
  height: 80rpx;
}

.wave {
  width: 8rpx;
  border-radius: 4rpx;
  background: rgba(102, 126, 234, 0.8);
  animation: wave-bounce 1.2s ease-in-out infinite;
}

.wave-1 { height: 30rpx; animation-delay: 0s; }
.wave-2 { height: 50rpx; animation-delay: 0.15s; }
.wave-3 { height: 70rpx; animation-delay: 0.3s; }
.wave-4 { height: 50rpx; animation-delay: 0.45s; }
.wave-5 { height: 30rpx; animation-delay: 0.6s; }

@keyframes wave-bounce {
  0%, 100% { transform: scaleY(0.4); opacity: 0.5; }
  50% { transform: scaleY(1); opacity: 1; }
}

/* Action buttons */
.actions {
  position: absolute;
  bottom: 160rpx;
  left: 0;
  width: 100%;
  z-index: 1;
  display: flex;
  justify-content: center;
}

.btn-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-row-double {
  width: 100%;
  justify-content: space-around;
  padding: 0 120rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-hangup, .btn-reject {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff4757 0%, #c0392b 100%);
  box-shadow: 0 8rpx 30rpx rgba(255, 71, 87, 0.4);
}

.btn-accept {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2ed573 0%, #27ae60 100%);
  box-shadow: 0 8rpx 30rpx rgba(46, 213, 115, 0.4);
}

.btn-hangup:active, .btn-reject:active { opacity: 0.8; transform: scale(0.95); }
.btn-accept:active { opacity: 0.8; transform: scale(0.95); }

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}
