.page-admin {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.user-main {
  display: flex;
  align-items: flex-start;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1976d2, #42a5f5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-avatar text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.user-username {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.user-detail {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.user-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-link {
  font-size: 26rpx;
  color: #1976d2;
  font-weight: 500;
  padding: 8rpx 16rpx;
}

.text-danger { color: #d32f2f !important; }
.text-success { color: #2e7d32 !important; }

/* Modal */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
}

.modal-dialog {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  z-index: 201;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin: 20rpx 0 12rpx;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: #f0f0f0;
  color: #666;
  border: 2rpx solid transparent;
}

.chip-selected {
  background: #e3f2fd;
  color: #1976d2;
  border-color: #1976d2;
  font-weight: 500;
}

.modal-actions {
  display: flex;
  margin-top: 30rpx;
}
