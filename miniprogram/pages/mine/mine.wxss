.page-mine {
  min-height: 100vh;
  background-color: #f5f6f7;
  padding-bottom: 40rpx;
}

/* Profile Header */
.profile-header {
  background: linear-gradient(135deg, #1976d2 0%, #0d47a1 100%);
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  margin-right: 28rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.avatar-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  text-transform: uppercase;
}

.profile-info {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.profile-role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  background-color: rgba(255, 255, 255, 0.15);
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
}

/* Menu Section */
.menu-section {
  background-color: #ffffff;
  margin: 20rpx 24rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-title {
  font-size: 24rpx;
  color: #999999;
  padding: 24rpx 0 12rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f6f7;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

/* Icon box design */
.menu-icon-box {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-char {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.menu-icon-blue { background-color: #1976d2; }
.menu-icon-green { background-color: #2e7d32; }
.menu-icon-orange { background-color: #ed6c02; }
.menu-icon-red { background-color: #d32f2f; }
.menu-icon-purple { background-color: #7b1fa2; }
.menu-icon-wx { background-color: #07c160; }
.menu-icon-grey { background-color: #757575; }

.menu-label {
  font-size: 28rpx;
  color: #333333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-value {
  font-size: 26rpx;
  color: #999999;
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: 24rpx;
  color: #cccccc;
}

/* WeChat Binding */
.wx-bound-tag {
  font-size: 22rpx;
  color: #07c160;
  background-color: #e8f8ef;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.wx-bind-btn {
  font-size: 26rpx;
  color: #1976d2;
  margin-right: 8rpx;
}

/* Logout */
.logout-section {
  padding: 40rpx 40rpx 40rpx;
}

.logout-btn {
  background-color: #ffffff;
  color: #d32f2f;
  border-radius: 16rpx;
  border: 2rpx solid #ffcdd2;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.logout-btn:active {
  background-color: #ffebee;
}
