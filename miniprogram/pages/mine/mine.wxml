<view class="page-mine">
  <!-- User Profile Header -->
  <view class="profile-header">
    <view class="avatar-wrap">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : (userInfo.username ? userInfo.username[0] : '?')}}</text>
      </view>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{userInfo.name || userInfo.username || '未知用户'}}</text>
      <text class="profile-role">{{userInfo.role_name || userInfo.role || '员工'}}</text>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-section">
    <view class="menu-title">个人设置</view>

    <view class="menu-item">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-blue">
          <text class="menu-icon-char">U</text>
        </view>
        <text class="menu-label">用户名</text>
      </view>
      <text class="menu-value">{{userInfo.username || '-'}}</text>
    </view>

    <view class="menu-item">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-char">T</text>
        </view>
        <text class="menu-label">手机号</text>
      </view>
      <text class="menu-value">{{userInfo.phone || '-'}}</text>
    </view>

    <picker mode="region" bindchange="onCityChange">
      <view class="menu-item">
        <view class="menu-left">
          <view class="menu-icon-box menu-icon-orange">
            <text class="menu-icon-char">C</text>
          </view>
          <text class="menu-label">所在城市</text>
        </view>
        <view class="menu-right">
          <text class="menu-value">{{cityText}}</text>
          <text class="menu-arrow">></text>
        </view>
      </view>
    </picker>
  </view>

  <!-- WeChat Binding Section -->
  <view class="menu-section">
    <view class="menu-title">微信绑定</view>

    <view class="menu-item" wx:if="{{wxBound}}">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-wx">
          <text class="menu-icon-char">W</text>
        </view>
        <text class="menu-label">微信账号</text>
      </view>
      <view class="menu-right">
        <text class="wx-bound-tag">已绑定</text>
        <text class="menu-value">{{wxOpenid.length > 8 ? wxOpenid.substring(0, 4) + '****' + wxOpenid.substring(wxOpenid.length - 4) : wxOpenid}}</text>
      </view>
    </view>

    <view class="menu-item" wx:else bindtap="handleBindWechat">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-wx">
          <text class="menu-icon-char">W</text>
        </view>
        <text class="menu-label">绑定微信</text>
      </view>
      <view class="menu-right">
        <text class="wx-bind-btn">{{wxBindLoading ? '绑定中...' : '去绑定'}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- Notification Settings -->
  <view class="menu-section">
    <view class="menu-title">通知设置</view>

    <view class="menu-item" bindtap="onNotifyToggle" data-field="notifyNewTicket">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-red">
          <text class="menu-icon-char">N</text>
        </view>
        <text class="menu-label">新工单通知</text>
      </view>
      <view class="menu-right">
        <switch checked="{{notifyNewTicket}}" color="#1976d2" style="transform: scale(0.8);" />
      </view>
    </view>

    <view class="menu-item" bindtap="onNotifyToggle" data-field="notifyStatusChange">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-purple">
          <text class="menu-icon-char">S</text>
        </view>
        <text class="menu-label">状态变更通知</text>
      </view>
      <view class="menu-right">
        <switch checked="{{notifyStatusChange}}" color="#1976d2" style="transform: scale(0.8);" />
      </view>
    </view>

    <view class="menu-item" bindtap="onNotifyToggle" data-field="notifyMessage">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-blue">
          <text class="menu-icon-char">M</text>
        </view>
        <text class="menu-label">消息通知</text>
      </view>
      <view class="menu-right">
        <switch checked="{{notifyMessage}}" color="#1976d2" style="transform: scale(0.8);" />
      </view>
    </view>
  </view>

  <!-- System Section -->
  <view class="menu-section">
    <view class="menu-title">系统</view>

    <view class="menu-item" bindtap="navigateToAbout">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-grey">
          <text class="menu-icon-char">i</text>
        </view>
        <text class="menu-label">关于</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">v1.0.0</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="handleClearCache">
      <view class="menu-left">
        <view class="menu-icon-box menu-icon-grey">
          <text class="menu-icon-char">D</text>
        </view>
        <text class="menu-label">清除缓存</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- Logout Button -->
  <view class="logout-section">
    <view class="logout-btn" bindtap="handleLogout">
      退出登录
    </view>
  </view>
</view>
