<view class="login-page">
  <!-- Header -->
  <view class="login-header">
    <view class="login-logo">
      <text class="logo-text">HM</text>
    </view>
    <text class="login-title">派单管理系统</text>
    <text class="login-subtitle">Dispatch Management System</text>
  </view>

  <!-- WeChat Login Button -->
  <view class="wx-login-section">
    <button
      class="btn btn-lg wx-login-btn {{wxLoading ? 'loading' : ''}}"
      bindtap="handleWxLogin"
      disabled="{{wxLoading}}"
    >
      <text class="wx-icon-text">W</text>
      <text>{{wxLoading ? '登录中...' : '微信一键登录'}}</text>
    </button>
  </view>

  <!-- Separator -->
  <view class="login-separator">
    <view class="separator-line"></view>
    <text class="separator-text">或使用账号密码登录</text>
    <view class="separator-line"></view>
  </view>

  <!-- Form -->
  <view class="login-form">
    <view class="form-item">
      <view class="input-wrap">
        <text class="input-icon-text">U</text>
        <input
          class="login-input"
          type="text"
          placeholder="请输入用户名"
          placeholder-style="color: rgba(255,255,255,0.5);"
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="30"
        />
      </view>
    </view>

    <view class="form-item">
      <view class="input-wrap">
        <text class="input-icon-text">P</text>
        <input
          class="login-input"
          type="text"
          placeholder="请输入密码"
          placeholder-style="color: rgba(255,255,255,0.5);"
          password="{{!showPassword}}"
          value="{{password}}"
          bindinput="onPasswordInput"
          maxlength="30"
        />
        <text class="toggle-pwd" bindtap="togglePassword">
          {{showPassword ? '隐藏' : '显示'}}
        </text>
      </view>
    </view>

    <button
      class="btn btn-lg login-btn {{loading ? 'loading' : ''}}"
      bindtap="handleLogin"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '登 录'}}
    </button>
  </view>

  <!-- Footer -->
  <view class="login-footer">
    <text class="footer-text">v1.0.0</text>
  </view>
</view>
