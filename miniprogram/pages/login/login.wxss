.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #2d8cf0 0%, #1a6dd1 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
  margin-bottom: 80rpx;
}

.login-logo {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.logo-icon {
  font-size: 60rpx;
  color: #ffffff;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.login-form {
  width: 100%;
}

.form-item {
  margin-bottom: 30rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  height: 96rpx;
  padding: 0 30rpx;
  backdrop-filter: blur(10px);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.login-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #ffffff;
}

.placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.toggle-pwd {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 10rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background-color: #ffffff;
  color: #2d8cf0;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 4rpx;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.9;
}

.login-btn.loading {
  opacity: 0.7;
}

.login-footer {
  position: fixed;
  bottom: 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}
