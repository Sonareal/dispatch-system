.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #1976d2 0%, #0d47a1 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 180rpx;
  margin-bottom: 60rpx;
}

.login-logo {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.logo-text {
  font-size: 52rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

/* WeChat Login Section */
.wx-login-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.wx-login-btn {
  width: 100% !important;
  background-color: #07c160 !important;
  color: #ffffff !important;
  font-weight: 600;
  border-radius: 16rpx !important;
  border: none !important;
  letter-spacing: 2rpx;
  padding: 0 !important;
  margin: 0 !important;
}

.wx-login-btn::after {
  border: none !important;
}

.wx-login-btn[disabled] {
  background-color: #07c160 !important;
  color: #ffffff !important;
  opacity: 0.7;
}

.wx-icon-text {
  font-size: 36rpx;
  font-weight: 700;
  margin-right: 12rpx;
  color: #ffffff;
}

/* Separator */
.login-separator {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.separator-line {
  flex: 1;
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.separator-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  padding: 0 24rpx;
  white-space: nowrap;
}

/* Form */
.login-form {
  width: 100%;
}

.form-item {
  margin-bottom: 30rpx;
}

.input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  height: 96rpx;
  padding: 0 30rpx;
}

.input-icon-text {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.7);
  width: 40rpx;
  text-align: center;
  margin-right: 20rpx;
}

.login-input {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  color: #ffffff;
  background: transparent;
  border: none;
  min-height: 96rpx;
}

.toggle-pwd {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 10rpx 0 10rpx 20rpx;
  white-space: nowrap;
}

/* Login Button */
.login-btn {
  width: 100% !important;
  background-color: #ffffff !important;
  color: #1976d2 !important;
  font-weight: 600;
  border-radius: 16rpx !important;
  border: none !important;
  margin-top: 20rpx;
  letter-spacing: 4rpx;
  padding: 0 !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
}

.login-btn::after {
  border: none !important;
}

.login-btn[disabled] {
  background-color: #ffffff !important;
  color: #1976d2 !important;
  opacity: 0.7;
}

.login-footer {
  position: fixed;
  bottom: 60rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}
